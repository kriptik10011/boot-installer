{
  "name": "weekly-review",
  "version": "1.0.0",
  "description": "Weekly command center for events, meals, and finances",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "node scripts/dev-full.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "cross-env WEEKLY_REVIEW_DEV_MODE=true TAURI_ENV_DEBUG_BUILD=true tauri dev",
    "sidecar:build": "cd backend && pyinstaller weekly-review-backend-x86_64-pc-windows-msvc.spec --noconfirm && cd .. && copy /Y backend\\dist\\weekly-review-backend-x86_64-pc-windows-msvc.exe src-tauri\\binaries\\weekly-review-backend-x86_64-pc-windows-msvc.exe",
    "build:production": "tsc && vite build",
    "build:debug": "tsc && cross-env VITE_DEBUG_BUILD=true vite build",
    "tauri:build": "npm run sidecar:build && npm run build:production && tauri build",
    "tauri:build:debug": "npm run sidecar:build && npm run build:debug && cross-env WEEKLY_REVIEW_DEV_MODE=true TAURI_ENV_DEBUG_BUILD=true tauri build",
    "update-shortcut": "powershell -ExecutionPolicy Bypass -File scripts/update-desktop-shortcut.ps1",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@react-three/a11y": "^3.0.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@tanstack/react-query": "^5.17.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.312.0",
    "postprocessing": "^6.38.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.7.0",
    "three": "^0.170.0",
    "uuid": "^13.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.170.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "fast-check": "^4.6.0",
    "happy-dom": "^20.6.1",
    "jsdom": "^24.0.0",
    "leva": "^0.10.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.6.1"
  }
}
